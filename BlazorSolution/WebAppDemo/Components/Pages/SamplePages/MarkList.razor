@using System.Collections.Generic
@using WebAppDemo.DataModels
@if (_assessmentMarks.Count() > 0)
{
    <br />
    <div class="row">
        <div class="col-md-12 text-center">
            <h3>Mark Table</h3>
        </div>
    </div>
    <div class="row">
        <div class="offset-2 col-md-8">
            <div class="overflow-scroll" style="height:450px;">
                <table class="table table-striped">
                    <thead style="position:sticky; top:0; background-color:white;">
                        <tr>
                            <th>Assessment</th>
                            <th>Weight</th>
                            <th>Mark</th>
                            <th>Max Mark</th>
                            <th>Weighted Mark</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _assessmentMarks)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.Weight</td>
                                <td>@item.Mark</td>
                                <td>@item.MaxMark</td>
                                <td>@item.WeightedMark</td>
                                @*
                                    add a button on the table to select for removal
                                    on the button the onclick will be setup to pass
                                        back the instance of the particular row
                                        you have click on
                                    the onclick will pass back to OnRemove the 
                                        instance that makes up the current row
                                *@
                                <td>
                                    <button class="btn btn-danger rounded-pill"
                                        @onclick="() => OnRemove.InvokeAsync(item)"
                                    >
                                        Remove
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <br />
    <div class="row">
        <div class="col-md-12 text-center">
            <h3>There are no marks on file.</h3>
        </div>
    </div>
}

@code {
    [Parameter]
    public IEnumerable<Assessment> _assessmentMarks { get; set; } //= IEnumerable.Empty<Assessment>();

    [Parameter]
    public EventCallback<Assessment> OnRemove{ get; set; }
}
