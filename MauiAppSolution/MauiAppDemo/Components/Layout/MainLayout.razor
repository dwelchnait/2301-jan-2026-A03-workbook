@inherits LayoutComponentBase

<!-- Additional namespace-->
@using MauiAppDemo.Helpers

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            <div style="background-color:@BackgroundColor; color:@TextColor; min-height:100vh;">
                @Body
            </div>
        </article>
    </main>
</div>
@code{
    private string Theme = Preferences.Get("app_theme", "light");
    private string BackgroundColor => Theme == "dark" ? "black" : "white";
    private string TextColor => Theme == "dark" ? "white" : "black";

    //these methods will assist in the immediate notification of preference changing
    protected override void OnInitialized()
    {
        PreferenceManager.OnPreferenceChanged += Refresh;
    }

    private void Refresh()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        PreferenceManager.OnPreferenceChanged -= Refresh;
    }
}